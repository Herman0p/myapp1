{
  "entities": {
    "Blog": {
      "title": "Blog Post",
      "description": "Educational articles and updates",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Post title" },
        "slug": { "type": "string", "description": "URL-friendly slug" },
        "content": { "type": "string", "description": "Markdown content" },
        "excerpt": { "type": "string", "description": "Short summary" },
        "coverImage": { "type": "string", "description": "URL to cover image" },
        "category": { "type": "string", "description": "Post category" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "author": { "type": "string", "description": "Author name" }
      },
      "required": ["title", "slug", "content", "createdAt"]
    },
    "Contact": {
      "title": "Contact Submission",
      "description": "Collaboration form submissions",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Sender name" },
        "email": { "type": "string", "format": "email", "description": "Sender email" },
        "subject": { "type": "string", "description": "Message subject" },
        "message": { "type": "string", "description": "Message content" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["name", "email", "message", "createdAt"]
    },
    "EduLead": {
      "title": "Education Lead",
      "description": "Leads from free resources/lead magnets",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "Lead email" },
        "resourceId": { "type": "string", "description": "ID of the resource requested" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Signup timestamp" }
      },
      "required": ["email", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "Professional services offered",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Service name" },
        "slug": { "type": "string", "description": "URL-friendly slug" },
        "description": { "type": "string", "description": "Detailed description" },
        "icon": { "type": "string", "description": "Icon name or URL" },
        "features": { "type": "array", "items": { "type": "string" }, "description": "List of features" }
      },
      "required": ["title", "slug", "description"]
    }
  },
  "firestore": {
    "blogs": { "schema": "Blog", "description": "Collection of blog posts" },
    "contacts": { "schema": "Contact", "description": "Collection of contact messages" },
    "edu_leads": { "schema": "EduLead", "description": "Collection of education leads" },
    "services": { "schema": "Service", "description": "Collection of services" }
  }
}
